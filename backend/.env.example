# ── OpenResearch Environment Variables ────────────────────────────────
# Copy this file to .env and fill in your keys:
#   cp .env.example .env

# Google Gemini API Key (free tier)
# Get yours at: https://aistudio.google.com/apikey
GOOGLE_API_KEY=your_google_api_key_here

# Semantic Scholar API Key
# 1 request per second rate limit
S2_API_KEY=your_s2_api_key_here

# PubMed / NCBI E-utilities API Key
# Get yours at: https://www.ncbi.nlm.nih.gov/account/settings/
NCBI_API_KEY=your_ncbi_api_key_here

# OpenAlex — Contact email for polite pool (faster rate limits, no API key needed)
# Data is 100% free (CC0). See: https://docs.openalex.org/how-to-use-the-api/rate-limits-and-authentication
OPENALEX_EMAIL=your_email@example.com
